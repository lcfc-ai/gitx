<Application
    x:Class="GitX.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:GitX.Core.Helpers"
    xmlns:views="clr-namespace:GitX.Views"
    DispatcherUnhandledException="OnDispatcherUnhandledException"
    Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <!--  转换器  -->
            <helpers:BoolToBranchIconConverter x:Key="BoolToBranchIcon" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <helpers:NullToVisibilityConverter x:Key="NullToVisibility" />
            <helpers:FileFolderIconConverter x:Key="FileFolderIcon" />

            <!--  全局颜色资源  -->
            <SolidColorBrush x:Key="BgBrush" Color="#1C1A18" />
            <SolidColorBrush x:Key="Bg2Brush" Color="#24211E" />
            <SolidColorBrush x:Key="Bg3Brush" Color="#2D2925" />
            <SolidColorBrush x:Key="BorderBrush" Color="#3B362F" />
            <SolidColorBrush x:Key="TextBrush" Color="#D7D1C5" />
            <SolidColorBrush x:Key="TextDimBrush" Color="#958C7D" />
            <SolidColorBrush x:Key="AccentBrush" Color="#AFA07A" />
            <SolidColorBrush x:Key="Accent2Brush" Color="#87917B" />
            <SolidColorBrush x:Key="GreenBrush" Color="#8FA27A" />
            <SolidColorBrush x:Key="RedBrush" Color="#C3776F" />
            <SolidColorBrush x:Key="YellowBrush" Color="#B79C61" />
            <SolidColorBrush x:Key="AddBgBrush" Color="#263026" />
            <SolidColorBrush x:Key="DelBgBrush" Color="#322321" />
            <SolidColorBrush x:Key="SelectionBrush" Color="#26221E" />
            <SolidColorBrush x:Key="SelectionBorderBrush" Color="#6E634C" />
            <SolidColorBrush x:Key="HoverBrush" Color="#2B2723" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2B2622" />
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#24201D" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#D7D1C5" />
            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#D7D1C5" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#25221E" />
            <SolidColorBrush x:Key="Surface2Brush" Color="#2D2924" />
            <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="#1E1A17" />
            <SolidColorBrush x:Key="ScrollbarTrackBorderBrush" Color="#3A342D" />
            <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#5E574C" />
            <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="#756D5F" />
            <SolidColorBrush x:Key="ScrollbarThumbPressedBrush" Color="#AFA07A" />
            <SolidColorBrush x:Key="MenuBorderBrush" Color="#3A342D" />
            <SolidColorBrush x:Key="MenuHoverBrush" Color="#302B26" />

            <!--  全局字体  -->
            <FontFamily x:Key="GlobalFont">Segoe UI, Microsoft YaHei, sans-serif</FontFamily>
            <FontFamily x:Key="CodeFont">Consolas, Fira Code, Courier New, monospace</FontFamily>

            <!--  全局控件样式  -->
            <Style BasedOn="{StaticResource DarkWindow}" TargetType="Window">
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource Bg3Brush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
                <Setter Property="SelectionBrush" Value="{StaticResource SelectionBrush}" />
                <Setter Property="SelectionOpacity" Value="1" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
                <Setter Property="Background" Value="{StaticResource ScrollbarThumbBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ScrollbarTrackBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="MinWidth" Value="12" />
                <Setter Property="MinHeight" Value="12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border
                                x:Name="ThumbChrome"
                                Margin="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999"
                                SnapsToDevicePixels="True" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource ScrollbarThumbHoverBrush}" />
                                    <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource ScrollbarThumbPressedBrush}" />
                                    <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{StaticResource ScrollbarThumbPressedBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ThumbChrome" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ContextMenu">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource MenuBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="2" />
                <Setter Property="HasDropShadow" Value="True" />
            </Style>

            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border
                                x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ContentSource="Icon" />
                                    <ContentPresenter
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        ContentSource="Header"
                                        RecognizesAccessKey="True" />
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource MenuHoverBrush}" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource MenuBorderBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="MinWidth" Value="12" />
                <Setter Property="MinHeight" Value="12" />
                <Setter Property="Width" Value="14" />
                <Setter Property="Height" Value="14" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource ScrollbarThumbBrush}" />
                <Setter Property="Opacity" Value="0.95" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid
                                x:Name="Root"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                                <Border
                                    x:Name="TrackChrome"
                                    Margin="1"
                                    Background="{StaticResource ScrollbarTrackBrush}"
                                    BorderBrush="{StaticResource ScrollbarTrackBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Opacity="0.45" />
                                <Track
                                    x:Name="PART_Track"
                                    Margin="2"
                                    Focusable="False"
                                    IsDirectionReversed="True"
                                    Orientation="{TemplateBinding Orientation}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton
                                            Width="0"
                                            Height="0"
                                            Background="Transparent"
                                            BorderBrush="{x:Null}"
                                            BorderThickness="0"
                                            Focusable="False"
                                            Command="ScrollBar.LineUpCommand"
                                            Style="{x:Null}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton
                                            Width="0"
                                            Height="0"
                                            Background="Transparent"
                                            BorderBrush="{x:Null}"
                                            BorderThickness="0"
                                            Focusable="False"
                                            Command="ScrollBar.LineDownCommand"
                                            Style="{x:Null}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TrackChrome" Property="Opacity" Value="0.75" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.55" />
                                </Trigger>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Height" Value="12" />
                                    <Setter Property="Width" Value="Auto" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ListView">
                <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>

            <Style TargetType="TreeView">
                <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>

            <Style TargetType="TreeViewItem">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style TargetType="ListViewItem">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <!--  全局按钮样式  -->
            <Style x:Key="BaseButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource HoverBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.4" />
                        <Setter Property="Cursor" Value="No" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  工具栏小按钮  -->
            <Style
                x:Key="SmallButton"
                BasedOn="{StaticResource BaseButton}"
                TargetType="Button">
                <Setter Property="Padding" Value="5,3" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style
                x:Key="ChromeButton"
                BasedOn="{StaticResource BaseButton}"
                TargetType="Button">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="26" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter
                                    Margin="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource HoverBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style
                x:Key="ChromeCloseButton"
                BasedOn="{StaticResource ChromeButton}"
                TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource RedBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource BgBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  全局窗口样式  -->
            <Style x:Key="DarkWindow" TargetType="Window">
                <Setter Property="Background" Value="{StaticResource BgBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style
                x:Key="ChromeWindow"
                BasedOn="{StaticResource DarkWindow}"
                TargetType="{x:Type views:ThemedWindow}">
                <Setter Property="WindowStyle" Value="None" />
                <Setter Property="ResizeMode" Value="CanResize" />
                <Setter Property="AllowsTransparency" Value="False" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
