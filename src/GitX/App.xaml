<Application
    x:Class="GitX.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:GitX.Core.Helpers"
    xmlns:views="clr-namespace:GitX.Views"
    DispatcherUnhandledException="OnDispatcherUnhandledException"
    Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <!--  转换器  -->
            <helpers:BoolToBranchIconConverter x:Key="BoolToBranchIcon" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <helpers:NullToVisibilityConverter x:Key="NullToVisibility" />
            <helpers:FileFolderIconConverter x:Key="FileFolderIcon" />

            <!--  全局字体  -->
            <FontFamily x:Key="GlobalFont">Segoe UI, Microsoft YaHei, sans-serif</FontFamily>
            <FontFamily x:Key="CodeFont">Consolas, Fira Code, Courier New, monospace</FontFamily>

            <!--  全局控件样式  -->
            <Style BasedOn="{StaticResource DarkWindow}" TargetType="Window">
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{DynamicResource Bg3Brush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
                <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBrush}" />
                <Setter Property="SelectionOpacity" Value="1" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
                <Setter Property="Background" Value="{DynamicResource ScrollbarThumbBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ScrollbarTrackBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="MinWidth" Value="12" />
                <Setter Property="MinHeight" Value="12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border
                                x:Name="ThumbChrome"
                                Margin="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999"
                                SnapsToDevicePixels="True" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource ScrollbarThumbHoverBrush}" />
                                    <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource ScrollbarThumbPressedBrush}" />
                                    <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{DynamicResource ScrollbarThumbPressedBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ThumbChrome" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ContextMenu">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource MenuBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="2" />
                <Setter Property="HasDropShadow" Value="True" />
            </Style>

            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Icon" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border
                                x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource MenuHoverBrush}" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource MenuBorderBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="MinWidth" Value="12" />
                <Setter Property="MinHeight" Value="12" />
                <Setter Property="Width" Value="14" />
                <Setter Property="Height" Value="14" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource ScrollbarThumbBrush}" />
                <Setter Property="Opacity" Value="0.95" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid
                                x:Name="Root"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                                <Border
                                    x:Name="TrackChrome"
                                    Margin="1"
                                    Background="{DynamicResource ScrollbarTrackBrush}"
                                    BorderBrush="{DynamicResource ScrollbarTrackBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Opacity="0.45" />
                                <Track
                                    x:Name="PART_Track"
                                    Margin="2"
                                    Focusable="False"
                                    IsDirectionReversed="True"
                                    Orientation="{TemplateBinding Orientation}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton
                                            Width="0"
                                            Height="0"
                                            Background="Transparent"
                                            BorderBrush="{x:Null}"
                                            BorderThickness="0"
                                            Focusable="False"
                                            Command="ScrollBar.LineUpCommand"
                                            Style="{x:Null}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton
                                            Width="0"
                                            Height="0"
                                            Background="Transparent"
                                            BorderBrush="{x:Null}"
                                            BorderThickness="0"
                                            Focusable="False"
                                            Command="ScrollBar.LineDownCommand"
                                            Style="{x:Null}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TrackChrome" Property="Opacity" Value="0.75" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.55" />
                                </Trigger>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Height" Value="12" />
                                    <Setter Property="Width" Value="Auto" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ListView">
                <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            </Style>

            <Style TargetType="TreeView">
                <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            </Style>

            <Style TargetType="TreeViewItem">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style TargetType="ListViewItem">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <!--  全局按钮样式  -->
            <Style x:Key="BaseButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.4" />
                        <Setter Property="Cursor" Value="No" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  工具栏小按钮  -->
            <Style
                x:Key="SmallButton"
                BasedOn="{StaticResource BaseButton}"
                TargetType="Button">
                <Setter Property="Padding" Value="5,3" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style
                x:Key="ChromeButton"
                BasedOn="{StaticResource BaseButton}"
                TargetType="Button">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="26" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter
                                    Margin="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style
                x:Key="ChromeCloseButton"
                BasedOn="{StaticResource ChromeButton}"
                TargetType="Button">
                <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource RedBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource BgBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  全局窗口样式  -->
            <Style x:Key="DarkWindow" TargetType="Window">
                <Setter Property="Background" Value="{DynamicResource BgBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource GlobalFont}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style
                x:Key="ChromeWindow"
                BasedOn="{StaticResource DarkWindow}"
                TargetType="{x:Type views:ThemedWindow}">
                <Setter Property="WindowStyle" Value="None" />
                <Setter Property="ResizeMode" Value="CanResize" />
                <Setter Property="AllowsTransparency" Value="False" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
