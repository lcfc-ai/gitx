<Application
    x:Class="GitX.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:GitX.Core.Helpers"
    DispatcherUnhandledException="OnDispatcherUnhandledException"
    Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <!--  全局字体  -->
            <FontFamily x:Key="GlobalFont">Segoe UI, Microsoft YaHei, sans-serif</FontFamily>
            <FontFamily x:Key="CodeFont">Consolas, Fira Code, Courier New, monospace</FontFamily>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Common/Converters.xaml" />
                <ResourceDictionary Source="Styles/Common/Windows.xaml" />
                <ResourceDictionary Source="Styles/Common/Inputs.xaml" />
                <ResourceDictionary Source="Styles/Common/Selectors.xaml" />
                <ResourceDictionary Source="Styles/Common/Buttons.xaml" />
                <ResourceDictionary Source="Styles/MainWindow.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
