<views:ThemedWindow
    x:Class="GitX.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:GitX.Core.Models"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:views="clr-namespace:GitX.Views"
    xmlns:vm="clr-namespace:GitX.ViewModels"
    Title="GitX - 分支对比"
    Width="1200"
    Height="800"
    MinWidth="800"
    MinHeight="500"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
    Background="{DynamicResource BgBrush}"
    FontFamily="{DynamicResource GlobalFont}"
    FontSize="13"
    Foreground="{DynamicResource TextBrush}"
    Style="{DynamicResource ChromeWindow}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="6"
            GlassFrameThickness="0"
            NonClientFrameEdges="None"
            ResizeBorderThickness="6" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!--  文件/文件夹图标转换器  -->
        <helpers:FileFolderIconConverter xmlns:helpers="clr-namespace:GitX.Core.Helpers" x:Key="FileFolderIcon" />

        <effects:DropShadowEffect
            x:Key="SoftPanelShadow"
            BlurRadius="14"
            Opacity="0.55"
            ShadowDepth="1"
            Color="#55000000" />
        <effects:DropShadowEffect
            x:Key="FloatingShadow"
            BlurRadius="18"
            Opacity="0.6"
            ShadowDepth="2"
            Color="#66000000" />

        <Style x:Key="CenteredBadgeText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="TreeContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="HasDropShadow" Value="True" />
        </Style>

        <Style x:Key="TreeMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="10,6" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{DynamicResource BorderBrush}" Height="1" Opacity="0.7" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TreeMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconChrome"
                                        Width="24"
                                        Height="24"
                                        Background="{DynamicResource Bg3Brush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ContentSource="Icon" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                    <ContentPresenter ContentSource="Header" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource MenuBorderBrush}" />
                                <Setter TargetName="IconChrome" Property="Background" Value="{DynamicResource Surface2Brush}" />
                                <Setter TargetName="IconChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  TreeView 展开箭头  -->
        <Style x:Key="TreeExpanderToggleStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <Path
                                x:Name="Arrow"
                                Width="8"
                                Height="8"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M 0 0 L 0 8 L 5 4 Z"
                                Fill="{DynamicResource TextDimBrush}"
                                RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Arrow" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  文件/文件夹 TreeView 数据模板  -->
        <HierarchicalDataTemplate DataType="{x:Type model:DiffTreeModel}" ItemsSource="{Binding Children}">
            <Grid HorizontalAlignment="Stretch" ToolTip="{Binding FullPath}">
                <Grid.ContextMenu>
                    <ContextMenu Style="{StaticResource TreeContextMenuStyle}">
                        <MenuItem
                            Style="{StaticResource TreeMenuItemStyle}"
                            Command="{Binding DataContext.OverwriteSelectedFileCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                            Header="覆盖此文件"
                            Icon="⬇"
                            Visibility="{Binding IsFile, Converter={StaticResource BoolToVisibility}}" />
                        <MenuItem
                            Style="{StaticResource TreeMenuItemStyle}"
                            Command="{Binding DataContext.OverwriteSelectedFolderCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                            Header="覆盖整个文件夹"
                            Icon="⬇"
                            Visibility="{Binding IsFile, Converter={StaticResource InverseBoolToVisibility}}" />
                        <Separator Style="{StaticResource TreeMenuSeparatorStyle}" />
                        <MenuItem
                            Style="{StaticResource TreeMenuItemStyle}"
                            Command="{Binding DataContext.RefreshDiffCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                            Header="刷新差异"
                            Icon="↻" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{Binding ChangeTypeColor}"
                    Text="{Binding IsFile, Converter={StaticResource FileFolderIcon}}" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{Binding Name}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="{Binding DisplayForegroundColor}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFile}" Value="True">
                                    <Setter Property="FontSize" Value="11.5" />
                                    <Setter Property="FontWeight" Value="Normal" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFile}" Value="False">
                                    <Setter Property="FontSize" Value="12.5" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Margin="4,0,4,0"
                        Padding="6,1"
                        Background="{Binding BadgeBackgroundColor}"
                        BorderBrush="{Binding ChangeTypeColor}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Visibility="{Binding IsFile, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="{Binding ChangeTypeColor}"
                            Style="{StaticResource CenteredBadgeText}"
                            Text="{Binding ChangeTypeCode}" />
                    </Border>
                    <Border
                        Margin="4,0,0,0"
                        Padding="6,1"
                        Background="{Binding FolderStatsBackgroundColor}"
                        BorderBrush="{Binding FolderStatsColor}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Visibility="{Binding IsFile, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="{Binding FolderStatsColor}"
                            Style="{StaticResource CenteredBadgeText}"
                            Text="{Binding FolderStatsSummary}" />
                    </Border>
                </StackPanel>
            </Grid>
        </HierarchicalDataTemplate>

        <!--  TreeViewItem 样式  -->
        <Style x:Key="DiffTreeItem" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border
                                x:Name="RowChrome"
                                Grid.Row="0"
                                Padding="1"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                MouseLeftButtonDown="OnDiffTreeItemRowMouseLeftButtonDown">
                                <Grid MinHeight="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        x:Name="AccentBar"
                                        Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="4,0,0,4" />

                                    <Path
                                        x:Name="ExpanderGlyph"
                                        Grid.Column="1"
                                        Width="7"
                                        Height="7"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 0 7 L 5 3.5 Z"
                                        Fill="{DynamicResource TextDimBrush}"
                                        RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </Path.RenderTransform>
                                    </Path>

                                    <ContentPresenter
                                        x:Name="PART_Header"
                                        Grid.Column="2"
                                        Margin="0"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        ContentSource="Header"
                                        RecognizesAccessKey="True" />
                                </Grid>
                            </Border>

                            <ItemsPresenter
                                x:Name="ItemsHost"
                                Grid.Row="1"
                                Margin="12,1,0,0" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="ExpanderGlyph" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpanderGlyph" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFile}" Value="False" />
                                    <Condition Binding="{Binding IsExpanded}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource SurfaceBrush}" />
                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource MenuBorderBrush}" />
                                <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource Accent2Brush}" />
                            </MultiDataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource MenuBorderBrush}" />
                                <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource SelectionBrush}" />
                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource SelectionBorderBrush}" />
                                <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="Selector.IsSelectionActive" Value="False">
                                <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource SelectionBrush}" />
                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource SelectionBorderBrush}" />
                                <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsFile}" Value="False" />
                        <Condition Binding="{Binding IsExpanded}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!--  分隔条样式  -->
        <Style x:Key="GridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Width" Value="5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Width="{TemplateBinding Width}" Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!--  自定义标题栏  -->
        <Border
            Padding="10,6"
            Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top"
            MouseLeftButtonDown="OnChromeMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="26"
                        Height="26"
                        Margin="0,0,10,0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AccentBrush}"
                            Text="G" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextBrush}"
                            Text="GitX 分支对比" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button
                        Margin="0,0,6,0"
                        Click="OnMinimizeClick"
                        Content="─"
                        Style="{DynamicResource ChromeButton}" />
                    <Button
                        Margin="0,0,6,0"
                        Click="OnToggleMaximizeClick"
                        Content="▢"
                        Style="{DynamicResource ChromeButton}" />
                    <Button
                        Click="OnCloseClick"
                        Content="×"
                        Style="{DynamicResource ChromeCloseButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  顶部工具栏  -->
        <Border
            Padding="12,8"
            Background="{DynamicResource Bg2Brush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="6,2"
                    Background="{DynamicResource Bg3Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AccentBrush}"
                        Style="{StaticResource CenteredBadgeText}"
                        Text="{Binding CurrentBranchDisplay}" />
                </Border>

                <Border
                    Grid.Column="1"
                    Margin="0,0,12,0"
                    Padding="6,2"
                    Background="{DynamicResource Bg3Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Accent2Brush}"
                        Style="{StaticResource CenteredBadgeText}"
                        Text="{Binding TargetBranchDisplay}" />
                </Border>

                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding RefreshDiffCommand}"
                        Content="🔄 刷新"
                        Style="{DynamicResource SmallButton}" />
                    <Button
                        Command="{Binding OverwriteAllFilesCommand}"
                        Content="⬇ 全部下载"
                        Style="{DynamicResource SmallButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  底部状态栏  -->
        <Border
            Padding="12,6"
            Background="{DynamicResource Bg2Brush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{DynamicResource TextDimBrush}"
                    Text="{Binding StatusBarText}" />
            </Grid>
        </Border>

        <!--  主体区域  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="280"
                    MinWidth="160"
                    MaxWidth="500" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  左侧：差异目录树  -->
            <Border
                Grid.Column="0"
                Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  树头  -->
                    <Border
                        Grid.Row="0"
                        Padding="10,10,10,7"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <Grid>
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource TextDimBrush}"
                                        Text="差异文件" />
                                    <Border
                                        Padding="5,1"
                                        HorizontalAlignment="Right"
                                        Background="{DynamicResource Surface2Brush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                        <TextBlock
                                            FontSize="9"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Style="{StaticResource CenteredBadgeText}"
                                            Text="{Binding TotalChangeCount}" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  搜索栏  -->
                    <Border
                        Grid.Row="1"
                        Margin="10,6,10,6"
                        Padding="8,6"
                        Background="{DynamicResource BgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Effect="{StaticResource FloatingShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{DynamicResource TextDimBrush}"
                                Text="⌕" />
                            <Border
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="8,4"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <TextBox
                                    x:Name="TreeFilterBox"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CaretBrush="{DynamicResource AccentBrush}"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextBrush}"
                                    Text="{Binding TreeFilterText, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                            <Button
                                Grid.Column="2"
                                Width="24"
                                Height="24"
                                Margin="8,0,0,0"
                                Command="{Binding ClearTreeFilterCommand}"
                                Content="×"
                                Style="{DynamicResource SmallButton}" />
                        </Grid>
                    </Border>

                    <!--  工具栏  -->
                    <!--  文件树  -->
                    <TreeView
                        Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource DiffTreeItem}"
                        ItemsSource="{Binding DiffTreeRoot}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectedItemChanged="OnTreeSelectedItemChanged"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling" />
                </Grid>
            </Border>

            <!--  分隔条  -->
            <GridSplitter
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Style="{StaticResource GridSplitterStyle}" />

            <!--  右侧：双栏 Diff 编辑器  -->
            <Grid Grid.Column="2" Background="{DynamicResource BgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  加载状态  -->
                <Grid
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Panel.ZIndex="10"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,0,12"
                            HorizontalAlignment="Center"
                            FontSize="48"
                            Text="⏳" />
                        <TextBlock
                            FontSize="14"
                            Foreground="{DynamicResource TextDimBrush}"
                            Text="正在计算差异..." />
                    </StackPanel>
                </Grid>

                <!--  文件头  -->
                <Border
                    Grid.Row="0"
                    Padding="12,8"
                    Background="{DynamicResource Bg2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AccentBrush}"
                                    Text="{Binding SelectedNodeTitle}" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="10"
                                    Foreground="{DynamicResource TextDimBrush}"
                                    Text="{Binding SelectedNodeSubtitle}" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding PreviousDiffCommand}"
                                Content="↑ 上一处"
                                IsEnabled="{Binding CanMoveToPreviousDiff}"
                                Style="{DynamicResource SmallButton}" />
                            <Button
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding NextDiffCommand}"
                                Content="↓ 下一处"
                                IsEnabled="{Binding CanMoveToNextDiff}"
                                Style="{DynamicResource SmallButton}" />
                            <Border
                                Grid.Column="3"
                                Margin="8,0,0,0"
                                Padding="8,2"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AccentBrush}"
                                    Text="{Binding CurrentDiffPositionText}" />
                            </Border>
                            <Button
                                Grid.Column="3"
                                Margin="8,0,0,0"
                                Command="{Binding OverwriteSelectedFileCommand}"
                                Content="⬇ 下载此文件"
                                Style="{DynamicResource SmallButton}"
                                Visibility="{Binding SelectedTreeNode.IsFile, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>

                        <Border
                            Margin="0,6,0,0"
                            Padding="7,4"
                            Background="{DynamicResource BgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Visibility="{Binding SelectedTreeNode, Converter={StaticResource NullToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontSize="9"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextDimBrush}"
                                    Text="{Binding DiffOverviewText}"
                                    TextAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!--  统一 diff 视图  -->
                <Grid Grid.Row="1">
                    <ae:TextEditor
                        x:Name="DiffEditor"
                        Background="{DynamicResource BgBrush}"
                        FontFamily="{DynamicResource CodeFont}"
                        FontSize="12"
                        Foreground="{DynamicResource TextBrush}"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        ShowLineNumbers="True"
                        VerticalScrollBarVisibility="Auto"
                        WordWrap="False" />

                    <!--  二进制文件提示  -->
                    <Grid Background="{DynamicResource BgBrush}" Visibility="{Binding IsBinaryFile, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock
                                Margin="0,0,0,12"
                                HorizontalAlignment="Center"
                                FontSize="48"
                                Text="📦" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="{DynamicResource TextDimBrush}"
                                Text="二进制文件" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</views:ThemedWindow>
