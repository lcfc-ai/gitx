<views:ThemedWindow
    x:Class="GitX.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:GitX.Core.Models"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:views="clr-namespace:GitX.Views"
    xmlns:vm="clr-namespace:GitX.ViewModels"
    Title="GitX - 分支对比"
    Width="1200"
    Height="820"
    MinWidth="800"
    MinHeight="500"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
    Background="{DynamicResource BgBrush}"
    FontFamily="{DynamicResource GlobalFont}"
    FontSize="13"
    Foreground="{DynamicResource TextBrush}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="6"
            GlassFrameThickness="0"
            NonClientFrameEdges="None"
            ResizeBorderThickness="6" />
    </shell:WindowChrome.WindowChrome>

    <DockPanel>
        <views:MainWindowHeader DockPanel.Dock="Top" />

        <!--  底部状态栏  -->
        <Border
            Padding="14,6"
            Background="{DynamicResource Bg2Brush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="11"
                Foreground="{DynamicResource TextDimBrush}"
                Text="{Binding StatusBarText}"
                TextTrimming="CharacterEllipsis" />
        </Border>

        <!--  主体区域  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="280"
                    MinWidth="160"
                    MaxWidth="500" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <views:DiffTreePane x:Name="DiffTreePaneControl" Grid.Column="0" />

            <GridSplitter
                Grid.Column="1"
                Width="4"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource BorderBrush}" />

            <Grid Grid.Column="2" Background="{DynamicResource BgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="5" />
                    <RowDefinition x:Name="PathHistoryRow" Height="340" MinHeight="0" />
                </Grid.RowDefinitions>

                <!--  加载状态：只覆盖 DiffEditor（Row 1），文件头和按钮继续可见  -->
                <Grid
                    Grid.Row="1"
                    Panel.ZIndex="10"
                    Background="{DynamicResource BgBrush}"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar
                            Width="160"
                            Height="3"
                            Margin="0,0,0,12"
                            IsIndeterminate="True"
                            Style="{DynamicResource ThinProgressBar}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="{DynamicResource TextDimBrush}"
                            Text="正在计算差异..." />
                    </StackPanel>
                </Grid>

                <GridSplitter
                    Grid.Row="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource BorderBrush}"
                    ResizeBehavior="PreviousAndNext"
                    ShowsPreview="True" />

                <!--  文件头：分上下两行，文件名独占一行  -->
                <Border
                    Grid.Row="0"
                    Padding="14,10"
                    Background="{DynamicResource Bg2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  第 1 行：文件路径（最大字号）+ 右上角操作组  -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AccentBrush}"
                                    Text="{Binding SelectedNodeTitle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Margin="10,3,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    Foreground="{DynamicResource TextDimBrush}"
                                    Text="{Binding SelectedNodeSubtitle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    MinWidth="64"
                                    Margin="0,0,6,0"
                                    Padding="10,3"
                                    Command="{Binding PreviousDiffCommand}"
                                    Content="上一处"
                                    FontSize="11"
                                    IsEnabled="{Binding CanMoveToPreviousDiff}" />
                                <Button
                                    MinWidth="64"
                                    Margin="0,0,6,0"
                                    Padding="10,3"
                                    Command="{Binding NextDiffCommand}"
                                    Content="下一处"
                                    FontSize="11"
                                    IsEnabled="{Binding CanMoveToNextDiff}" />
                                <Border
                                    Margin="0,0,10,0"
                                    Padding="8,2"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource Surface2Brush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Text="{Binding CurrentDiffPositionText}" />
                                </Border>
                                <Button
                                    MinWidth="86"
                                    Padding="10,3"
                                    Command="{Binding OverwriteSelectedFileCommand}"
                                    Content="下载此文件"
                                    FontSize="11"
                                    Foreground="{DynamicResource DangerBrush}"
                                    IsEnabled="{Binding SelectedTreeNode.IsFile}"
                                    ToolTip="将覆盖本地文件，请确认">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource ChromeButton}" TargetType="Button">
                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource DangerBgBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!--  第 2 行：变更概览（+12 -3 之类），左对齐  -->
                        <Border
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Padding="9,4"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource BgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Visibility="{Binding SelectedTreeNode, Converter={StaticResource NullToVisibility}}">
                            <TextBlock
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextDimBrush}"
                                Text="{Binding DiffOverviewText}" />
                        </Border>
                    </Grid>
                </Border>

                <!--  统一 diff 视图  -->
                <Grid Grid.Row="1">
                    <ae:TextEditor
                        x:Name="DiffEditor"
                        Background="{DynamicResource BgBrush}"
                        FontFamily="{DynamicResource CodeFont}"
                        FontSize="12"
                        Foreground="{DynamicResource TextBrush}"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        ShowLineNumbers="True"
                        VerticalScrollBarVisibility="Auto"
                        WordWrap="False" />

                    <Grid
                        Background="{DynamicResource BgBrush}"
                        Visibility="{Binding IsBinaryFile, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="13"
                                Foreground="{DynamicResource YellowBrush}"
                                Text="二进制文件，无法对比文本内容" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <!--  展开态：完整提交日志面板  -->
                <Grid Grid.Row="3" Visibility="{Binding IsPathHistoryCollapsed, Converter={StaticResource InverseBoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                <Border
                    Padding="12,8,12,10"
                    Background="{DynamicResource Bg2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  第 1 行：路径标题 + 当前筛选  -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource TextDimBrush}"
                                    Text="{Binding PathHistoryTitle}" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="10"
                                    Foreground="{DynamicResource Accent2Brush}"
                                    Text="{Binding PathHistorySubtitle}" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="10"
                                Foreground="{DynamicResource TextDimBrush}"
                                Text="按时间筛选" />
                        </Grid>

                        <!--  第 2 行：作者 + 时间（segmented control 风格，更紧凑）  -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    Foreground="{DynamicResource TextDimBrush}"
                                    Text="作者" />
                                <TextBox
                                    Width="180"
                                    Padding="8,3"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Text="{Binding PathHistoryAuthorFilter, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <ListBox
                                Grid.Column="2"
                                MinHeight="24"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding PathHistoryRecentDaysOptions}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                SelectedIndex="{Binding PathHistoryRecentDaysIndex, Mode=TwoWay}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="0,0,4,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border
                                                        x:Name="Root"
                                                        MinWidth="42"
                                                        Padding="9,2"
                                                        Background="{DynamicResource Bg3Brush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Surface2Brush}" />
                                                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Text="{Binding}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!--  第 3 行：左 commit 列表 + 分隔条 + 右 commit 详情  -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="0.95*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Padding="0"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="10,6,10,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="提交历史" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="{Binding PathHistoryRecentDaysLabel}" />
                                        <Button
                                            Grid.Column="2"
                                            Padding="6,1"
                                            VerticalAlignment="Center"
                                            Command="{Binding TogglePathHistoryCollapseCommand}"
                                            Content="{Binding PathHistoryCollapseIcon}"
                                            FontSize="10"
                                            ToolTip="折叠/展开提交日志面板" />
                                    </Grid>

                                    <ListView
                                        Grid.Row="1"
                                        Margin="6,0,6,6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemsSource="{Binding PathHistoryItems}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                                        SelectedItem="{Binding SelectedPathHistoryItem, Mode=TwoWay}"
                                        Visibility="{Binding HasPathHistoryItems, Converter={StaticResource BoolToVisibility}}">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                <Setter Property="IsTabStop" Value="False" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True" />
                                                            <Condition Property="Selector.IsSelectionActive" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
                                                    </MultiTrigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True" />
                                                            <Condition Property="Selector.IsSelectionActive" Value="False" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource Bg3Brush}" />
                                                    </MultiTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate DataType="{x:Type model:CommitHistoryItem}">
                                                <Grid Margin="0,0,0,1">
                                                    <Border
                                                        x:Name="AccentBar"
                                                        Width="3"
                                                        HorizontalAlignment="Left"
                                                        Background="Transparent" />
                                                    <Grid Margin="10,7,10,7">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="68" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                FontFamily="{DynamicResource CodeFont}"
                                                                FontSize="11"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AccentBrush}"
                                                                Text="{Binding ShortSha}"
                                                                ToolTip="{Binding Sha}" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                Margin="8,0,0,0"
                                                                FontSize="11"
                                                                Foreground="{DynamicResource TextBrush}"
                                                                Text="{Binding MessageShort}"
                                                                TextTrimming="CharacterEllipsis" />
                                                            <TextBlock
                                                                Grid.Column="2"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="10"
                                                                Foreground="{DynamicResource TextDimBrush}"
                                                                Text="{Binding CommitTimeRelative}"
                                                                ToolTip="{Binding CommitTimeText}" />
                                                        </Grid>
                                                        <StackPanel
                                                            Grid.Row="1"
                                                            Margin="0,3,0,0"
                                                            Orientation="Horizontal">
                                                            <TextBlock
                                                                FontSize="10"
                                                                Foreground="{DynamicResource Accent2Brush}"
                                                                Text="{Binding Author}"
                                                                TextTrimming="CharacterEllipsis"
                                                                ToolTip="{Binding AuthorDisplay}" />
                                                            <TextBlock
                                                                Margin="6,0,0,0"
                                                                FontSize="10"
                                                                Foreground="{DynamicResource TextDimBrush}"
                                                                Text="·" />
                                                            <TextBlock
                                                                Margin="6,0,0,0"
                                                                FontSize="10"
                                                                Foreground="{DynamicResource TextDimBrush}"
                                                                Text="{Binding CommitTimeText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                        <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <Border
                                        Background="{DynamicResource BgBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="{Binding HasPathHistoryItems, Converter={StaticResource InverseBoolToVisibility}}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="暂无提交记录" />
                                    </Border>

                                    <Grid
                                        Background="{DynamicResource BgBrush}"
                                        Visibility="{Binding IsPathHistoryLoading, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="正在加载提交记录..." />
                                    </Grid>
                                </Grid>
                            </Border>

                            <GridSplitter
                                Grid.Column="1"
                                Width="4"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource BorderBrush}"
                                ResizeBehavior="PreviousAndNext"
                                ShowsPreview="True" />

                            <Border
                                Grid.Column="2"
                                Padding="12,8"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Text="{Binding SelectedCommitTitle}"
                                            TextTrimming="CharacterEllipsis" />
                                        <Button
                                            Grid.Column="1"
                                            Padding="6,1"
                                            VerticalAlignment="Center"
                                            Command="{Binding CopyShaToClipboardCommand}"
                                            CommandParameter="{Binding SelectedCommitFullSha}"
                                            Content="复制 SHA"
                                            FontSize="10" />
                                    </Grid>

                                    <!--  元数据：作者邮箱 / 相对时间 / 完整 SHA / 父提交  -->
                                    <Grid Grid.Row="1" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,8,2"
                                            FontSize="10"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="作者" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            FontSize="10"
                                            Foreground="{DynamicResource TextBrush}"
                                            Text="{Binding SelectedCommitAuthorEmail}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,0,8,2"
                                            FontSize="10"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="时间" />
                                        <StackPanel
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="{DynamicResource TextBrush}"
                                                Text="{Binding SelectedCommitRelativeTime}" />
                                            <TextBlock
                                                Margin="6,0,0,0"
                                                FontSize="10"
                                                Foreground="{DynamicResource TextDimBrush}"
                                                Text="{Binding SelectedCommitDetail.Commit.CommitTimeText}" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            Margin="0,0,8,0"
                                            FontSize="10"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="父提交" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            FontSize="10"
                                            FontFamily="{DynamicResource CodeFont}"
                                            Foreground="{DynamicResource TextBrush}"
                                            Text="{Binding SelectedCommitParentShas}" />
                                    </Grid>

                                    <TextBlock
                                        Grid.Row="2"
                                        Margin="0,8,0,0"
                                        FontFamily="{DynamicResource CodeFont}"
                                        FontSize="11"
                                        Foreground="{DynamicResource TextBrush}"
                                        Text="{Binding SelectedCommitDetail.Commit.Message}"
                                        TextWrapping="Wrap" />

                                    <Grid Grid.Row="3" Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="影响文件" />
                                        <ScrollViewer
                                            Grid.Row="1"
                                            VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding SelectedCommitDetail.Files}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type model:CommitFileChangeItem}">
                                                        <Border
                                                            x:Name="RowRoot"
                                                            Margin="0,1,0,0"
                                                            Padding="8,4,4,4"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="2,0,0,0"
                                                            CornerRadius="3"
                                                            Cursor="Hand"
                                                            MouseLeftButtonUp="OnCommitFileClick"
                                                            ToolTip="点击跳转到该文件的 diff">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock
                                                                    Width="14"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontFamily="{DynamicResource CodeFont}"
                                                                    FontSize="10"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource Accent2Brush}"
                                                                    Text="{Binding StatusCode}" />
                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    Margin="6,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="10"
                                                                    Foreground="{DynamicResource TextBrush}"
                                                                    Text="{Binding DisplayPath}"
                                                                    TextTrimming="CharacterEllipsis" />
                                                                <StackPanel
                                                                    x:Name="ActionRow"
                                                                    Grid.Column="2"
                                                                    Margin="6,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Orientation="Horizontal"
                                                                    Visibility="Collapsed">
                                                                    <Button
                                                                        Padding="6,1"
                                                                        VerticalAlignment="Center"
                                                                        Command="{Binding DataContext.CopyFilePathCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Path}"
                                                                        Content="复制"
                                                                        FontSize="9"
                                                                        ToolTip="复制相对路径" />
                                                                    <Button
                                                                        Margin="4,0,0,0"
                                                                        Padding="6,1"
                                                                        VerticalAlignment="Center"
                                                                        Command="{Binding DataContext.OpenFileInExplorerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding Path}"
                                                                        Content="打开"
                                                                        FontSize="9"
                                                                        ToolTip="在文件管理器中定位" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <Trigger SourceName="RowRoot" Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="RowRoot" Property="Background" Value="{DynamicResource HoverBrush}" />
                                                                <Setter TargetName="ActionRow" Property="Visibility" Value="Visible" />
                                                            </Trigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>

                                    <Border
                                        Grid.RowSpan="4"
                                        Panel.ZIndex="1"
                                        Background="{DynamicResource BgBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="{Binding SelectedPathHistoryItem, Converter={StaticResource InverseNullToVisibility}, FallbackValue=Visible}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="点击左侧提交查看详情" />
                                    </Border>

                                    <Grid
                                        Grid.RowSpan="4"
                                        Panel.ZIndex="20"
                                        Background="{DynamicResource BgBrush}"
                                        Visibility="{Binding IsCommitDetailLoading, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextDimBrush}"
                                            Text="正在加载提交详情..." />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!--  折叠态：紧凑标题栏，悬浮在底部  -->
                <Border
                    Grid.Row="3"
                    Padding="14,5,14,5"
                    Background="{DynamicResource Bg2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Visibility="{Binding IsPathHistoryCollapsed, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextDimBrush}"
                            Text="提交日志" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="10"
                            Foreground="{DynamicResource Accent2Brush}"
                            Text="{Binding PathHistorySubtitle}"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Grid.Column="2"
                            Padding="6,1"
                            VerticalAlignment="Center"
                            Command="{Binding TogglePathHistoryCollapseCommand}"
                            Content="{Binding PathHistoryCollapseIcon}"
                            FontSize="10"
                            ToolTip="展开提交日志面板" />
                    </Grid>
                </Border>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</views:ThemedWindow>
