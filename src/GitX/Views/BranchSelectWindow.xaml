<views:ThemedWindow x:Class="GitX.Views.BranchSelectWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:views="clr-namespace:GitX.Views"
                    mc:Ignorable="d"
                    Title="GitX - 选择对比分支"
                    Height="520"
                    Width="520"
                    WindowStartupLocation="CenterScreen"
                    Background="{DynamicResource BgBrush}"
                    Foreground="{DynamicResource TextBrush}"
                    FontFamily="{DynamicResource GlobalFont}"
                    FontSize="13">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="6"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="6" />
    </shell:WindowChrome.WindowChrome>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12"
                MouseLeftButtonDown="OnChromeMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="选择要对比的分支"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="当前分支将保持不可选"
                               FontSize="11"
                               Foreground="{DynamicResource TextDimBrush}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="×"
                        Style="{DynamicResource ChromeCloseButton}"
                        Width="34"
                        Height="26"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="OnCloseClick" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,14,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="{DynamicResource Bg2Brush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="10,8"
                     FontSize="13"
                     CaretBrush="{DynamicResource TextBrush}" />

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Background="{DynamicResource Bg2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <ListView ItemsSource="{Binding FilteredBranches}"
                              SelectedItem="{Binding SelectedBranch}"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding IsLocalBranch, Converter={StaticResource BoolToBranchIcon}}"
                                               FontSize="14"
                                               Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayName}"
                                               FontSize="13" />
                                    <TextBlock Grid.Column="2"
                                               Text="当前"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibility}}"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock Text="正在读取分支..." Foreground="{DynamicResource TextDimBrush}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding FilteredBranches.Count, StringFormat='{}共 {0} 个分支'}"
                       Foreground="{DynamicResource TextDimBrush}" />
            <Button Grid.Column="1"
                    Content="取消"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="OnCancelClick" />
            <Button Grid.Column="2"
                    Content="确认对比"
                    Command="{Binding ConfirmCommand}"
                    IsDefault="True"
                    Click="OnConfirmClick" />
        </Grid>
    </Grid>
</views:ThemedWindow>
