<UserControl
    x:Class="GitX.Views.MainWindowHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="clr-namespace:GitX.Services"
    xmlns:views="clr-namespace:GitX.Views"
    Height="Auto">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Padding="10,4"
            Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="OnChromeMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="26"
                        Height="26"
                        Margin="0,0,10,0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AccentBrush}"
                            Text="G" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextBrush}"
                            Text="GitX 分支对比" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox
                        x:Name="ThemeSelector"
                        Width="148"
                        Height="24"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        FontSize="11"
                        SelectionChanged="OnThemeSelectionChanged" />
                    <Button
                        Margin="0,0,6,0"
                        Click="OnMinimizeClick"
                        Content="─"
                        Style="{DynamicResource ChromeButton}" />
                    <Button
                        Margin="0,0,6,0"
                        Click="OnToggleMaximizeClick"
                        Content="▢"
                        Style="{DynamicResource ChromeButton}" />
                    <Button
                        Click="OnCloseClick"
                        Content="×"
                        Style="{DynamicResource ChromeCloseButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Padding="12,8"
            Background="{DynamicResource Bg2Brush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border
                        Margin="0,0,8,0"
                        Padding="6,2"
                        Background="{DynamicResource Bg3Brush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextAlignment="Center"
                            Text="{Binding CurrentBranchDisplay}"
                            TextTrimming="CharacterEllipsis"
                            MaxWidth="200" />
                    </Border>

                    <Border
                        Margin="0,0,12,0"
                        Padding="6,2"
                        Background="{DynamicResource Bg3Brush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource Accent2Brush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextAlignment="Center"
                            Text="{Binding TargetBranchDisplay}"
                            TextTrimming="CharacterEllipsis"
                            MaxWidth="200" />
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Foreground="{DynamicResource Accent2Brush}"
                        MaxWidth="260"
                        Text="{Binding FetchProgressText}"
                        TextTrimming="CharacterEllipsis"
                        Visibility="{Binding IsFetchingRemote, Converter={StaticResource BoolToVisibility}}" />
                    <Button
                        Margin="0,0,6,0"
                        Command="{Binding FetchLatestCommand}"
                        Content="拉取最新"
                        IsEnabled="{Binding IsFetchingRemote, Converter={StaticResource InverseBool}}"
                        ToolTip="git fetch --all --prune，并把对比基线升级为 origin/&lt;branch&gt;（不动本地工作区与分支指针）" />
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding RefreshDiffCommand}"
                        Content="刷新"
                        IsEnabled="{Binding IsFetchingRemote, Converter={StaticResource InverseBool}}"
                        ToolTip="拉取远端 + 重新计算差异树" />
                    <Button
                        Command="{Binding OverwriteAllFilesCommand}"
                        Content="全部下载"
                        IsEnabled="{Binding IsFetchingRemote, Converter={StaticResource InverseBool}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
