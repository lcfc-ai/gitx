<UserControl
    x:Class="GitX.Views.DiffTreePane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="clr-namespace:GitX.Core.Models">
    <UserControl.Resources>
        <Style x:Key="DiffTreeItem" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border
                                x:Name="RowChrome"
                                Grid.Row="0"
                                Padding="1"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="4"
                                MouseLeftButtonDown="OnDiffTreeItemRowMouseLeftButtonDown">
                                <Grid MinHeight="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        x:Name="AccentBar"
                                        Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="4,0,0,4" />

                                    <Path
                                        x:Name="ExpanderGlyph"
                                        Grid.Column="1"
                                        Width="7"
                                        Height="7"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 0 7 L 5 3.5 Z"
                                        Fill="{DynamicResource TextDimBrush}"
                                        RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </Path.RenderTransform>
                                    </Path>

                                    <ContentPresenter
                                        x:Name="PART_Header"
                                        Grid.Column="2"
                                        Margin="0"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        ContentSource="Header"
                                        RecognizesAccessKey="True" />
                                </Grid>
                            </Border>

                            <ItemsPresenter
                                x:Name="ItemsHost"
                                Grid.Row="1"
                                Margin="12,1,0,0" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="ExpanderGlyph" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpanderGlyph" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFile}" Value="False" />
                                    <Condition Binding="{Binding IsExpanded}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="RowChrome" Property="Background" Value="{DynamicResource TreeRowExpandedBrush}" />
                            </MultiDataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="{DynamicResource TreeRowHoverBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Selector.IsSelectionActive" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowChrome" Property="Background" Value="{DynamicResource TreeRowSelectedBrush}" />
                                <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Selector.IsSelectionActive" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowChrome" Property="Background" Value="{DynamicResource TreeRowInactiveSelectedBrush}" />
                                <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource TextDimBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsFile}" Value="False" />
                        <Condition Binding="{Binding IsExpanded}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border
        Grid.Column="0"
        Background="{DynamicResource Bg2Brush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="10,10,10,7"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel>
                        <Grid>
                            <TextBlock
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextDimBrush}"
                                Text="差异文件" />
                            <Border
                                Padding="5,1"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                                <TextBlock
                                    FontSize="9"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AccentBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    TextAlignment="Center"
                                    Text="{Binding TotalChangeCount}" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Margin="10,6,10,6"
                Padding="8,6"
                Background="{DynamicResource BgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Effect="{StaticResource FloatingShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{DynamicResource TextDimBrush}"
                        Text="⌕" />
                    <Border
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Padding="8,4"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <TextBox
                            x:Name="TreeFilterBox"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{DynamicResource AccentBrush}"
                            FontSize="12"
                            Foreground="{DynamicResource TextBrush}"
                            Text="{Binding TreeFilterText, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                    <Button
                        Grid.Column="2"
                        Width="24"
                        Height="24"
                        Margin="8,0,0,0"
                        Command="{Binding ClearTreeFilterCommand}"
                        Content="×" />
                </Grid>
            </Border>

            <TreeView
                Grid.Row="2"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource DiffTreeItem}"
                ItemsSource="{Binding DiffTreeRoot}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectedItemChanged="OnTreeSelectedItemChanged"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling" />
        </Grid>
    </Border>
</UserControl>
