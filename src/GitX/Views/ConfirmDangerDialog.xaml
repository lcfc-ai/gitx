<Window
    x:Class="GitX.Views.ConfirmDangerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="危险操作确认"
    Width="500"
    MinHeight="240"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Border
        Background="{DynamicResource Bg2Brush}"
        BorderBrush="{DynamicResource DangerBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Border
                    Width="32"
                    Height="32"
                    Margin="0,0,12,0"
                    Background="{DynamicResource DangerBgBrush}"
                    CornerRadius="16">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource DangerBrush}"
                        Text="!" />
                </Border>
                <TextBlock
                    x:Name="TitleText"
                    VerticalAlignment="Center"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextBrush}" />
            </StackPanel>

            <TextBlock
                x:Name="MessageText"
                Grid.Row="1"
                Margin="0,16,0,0"
                FontSize="12"
                Foreground="{DynamicResource TextBrush}"
                TextWrapping="Wrap" />

            <StackPanel Grid.Row="2" Margin="0,16,0,0">
                <TextBlock
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextDimBrush}"
                    Text="请输入下方文字以确认：" />
                <Border
                    Margin="0,6,0,0"
                    Background="{DynamicResource BgBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <TextBox
                        x:Name="ConfirmInput"
                        Height="32"
                        Padding="10,4"
                        Background="Transparent"
                        BorderThickness="0"
                        CaretBrush="{DynamicResource AccentBrush}"
                        FontSize="13"
                        Foreground="{DynamicResource TextBrush}"
                        TextChanged="OnInputChanged" />
                </Border>
                <TextBlock
                    x:Name="HintText"
                    Margin="0,4,0,0"
                    FontSize="10"
                    Foreground="{DynamicResource TextDimBrush}" />
            </StackPanel>

            <StackPanel
                Grid.Row="3"
                Margin="0,16,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="80"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="OnCancelClick"
                    Content="取消" />
                <Button
                    x:Name="ConfirmButton"
                    Width="100"
                    Height="30"
                    Click="OnConfirmClick"
                    Content="确认覆盖"
                    IsEnabled="False"
                    Style="{DynamicResource DangerButton}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
