<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
                    xmlns:helpers="clr-namespace:GitX.Core.Helpers"
                    xmlns:model="clr-namespace:GitX.Core.Models">
    <helpers:FileFolderIconConverter x:Key="FileFolderIcon" />

    <effects:DropShadowEffect
        x:Key="SoftPanelShadow"
        BlurRadius="14"
        Opacity="0.55"
        ShadowDepth="1"
        Color="#55000000" />
    <effects:DropShadowEffect
        x:Key="FloatingShadow"
        BlurRadius="18"
        Opacity="0.6"
        ShadowDepth="2"
        Color="#66000000" />

    <Style x:Key="CenteredBadgeText" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style x:Key="TreeContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="HasDropShadow" Value="True" />
    </Style>

    <Style x:Key="TreeMenuSeparatorStyle" TargetType="Separator">
        <Setter Property="Margin" Value="10,6" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{DynamicResource BorderBrush}" Height="1" Opacity="0.7" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TreeMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid Margin="2,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="IconChrome"
                                    Width="18"
                                    Height="18"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ContentSource="Icon" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="6,0,6,0" VerticalAlignment="Center">
                                <ContentPresenter ContentSource="Header" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuHoverBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource MenuBorderBrush}" />
                            <Setter TargetName="IconChrome" Property="Background" Value="{DynamicResource Surface2Brush}" />
                            <Setter TargetName="IconChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="IconChrome" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <HierarchicalDataTemplate DataType="{x:Type model:DiffTreeModel}" ItemsSource="{Binding Children}">
        <Grid HorizontalAlignment="Stretch" ToolTip="{Binding FullPath}">
            <Grid.ContextMenu>
                <ContextMenu Style="{StaticResource TreeContextMenuStyle}">
                    <MenuItem
                        Style="{StaticResource TreeMenuItemStyle}"
                        Command="{Binding DataContext.OverwriteSelectedFileCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                        Header="覆盖此文件"
                        Icon="⬇"
                        Visibility="{Binding IsFile, Converter={StaticResource BoolToVisibility}}" />
                    <MenuItem
                        Style="{StaticResource TreeMenuItemStyle}"
                        Command="{Binding DataContext.OverwriteSelectedFolderCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                        Header="覆盖整个文件夹"
                        Icon="⬇"
                        Visibility="{Binding IsFile, Converter={StaticResource InverseBoolToVisibility}}" />
                    <Separator Style="{StaticResource TreeMenuSeparatorStyle}" />
                    <MenuItem
                        Style="{StaticResource TreeMenuItemStyle}"
                        Command="{Binding DataContext.RefreshDiffCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                        Header="刷新差异"
                        Icon="↻" />
                </ContextMenu>
            </Grid.ContextMenu>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{Binding ChangeTypeColor}"
                Text="{Binding IsFile, Converter={StaticResource FileFolderIcon}}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Text="{Binding Name}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{Binding DisplayForegroundColor}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFile}" Value="True">
                                <Setter Property="FontSize" Value="11.5" />
                                <Setter Property="FontWeight" Value="Normal" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsFile}" Value="False">
                                <Setter Property="FontSize" Value="12.5" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Border
                    Margin="4,0,4,0"
                    Padding="6,1"
                    Background="{Binding BadgeBackgroundColor}"
                    BorderBrush="{Binding ChangeTypeColor}"
                    BorderThickness="1"
                    CornerRadius="5"
                    Visibility="{Binding IsFile, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{Binding ChangeTypeColor}"
                        Style="{StaticResource CenteredBadgeText}"
                        Text="{Binding ChangeTypeCode}" />
                </Border>
                <Border
                    Margin="4,0,0,0"
                    Padding="6,1"
                    Background="{Binding FolderStatsBackgroundColor}"
                    BorderBrush="{Binding FolderStatsColor}"
                    BorderThickness="1"
                    CornerRadius="5"
                    Visibility="{Binding IsFile, Converter={StaticResource InverseBoolToVisibility}}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{Binding FolderStatsColor}"
                        Style="{StaticResource CenteredBadgeText}"
                        Text="{Binding FolderStatsSummary}" />
                </Border>
            </StackPanel>
        </Grid>
    </HierarchicalDataTemplate>

</ResourceDictionary>
