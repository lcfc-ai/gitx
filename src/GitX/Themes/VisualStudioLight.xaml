<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BgBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="Bg2Brush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Bg3Brush" Color="#F7F7F7" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D0D0D0" />
    <SolidColorBrush x:Key="TextBrush" Color="#1F1F1F" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#666666" />
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />
    <SolidColorBrush x:Key="Accent2Brush" Color="#3B82F6" />
    <SolidColorBrush x:Key="GreenBrush" Color="#2E8B57" />
    <SolidColorBrush x:Key="RedBrush" Color="#C73E3E" />
    <SolidColorBrush x:Key="YellowBrush" Color="#A37B00" />
    <SolidColorBrush x:Key="AddBgBrush" Color="#E7F4E8" />
    <SolidColorBrush x:Key="DelBgBrush" Color="#FCE8E8" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#DCEBFA" />
    <SolidColorBrush x:Key="SelectionBorderBrush" Color="#97C7F3" />
    <SolidColorBrush x:Key="HoverBrush" Color="#E9E9E9" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Surface2Brush" Color="#F0F4F8" />
    <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="#E4E4E4" />
    <SolidColorBrush x:Key="ScrollbarTrackBorderBrush" Color="#CFCFCF" />
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#A8A8A8" />
    <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="#8E8E8E" />
    <SolidColorBrush x:Key="ScrollbarThumbPressedBrush" Color="#007ACC" />
    <SolidColorBrush x:Key="MenuBorderBrush" Color="#D3D3D3" />
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#E7F1FB" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C73E3E" />
    <SolidColorBrush x:Key="DangerBgBrush" Color="#FCE8E8" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#2E8B57" />
