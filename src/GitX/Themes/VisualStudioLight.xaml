    <SolidColorBrush x:Key="TreeRowHoverBrush" Color="#F2F7FC" />
    <SolidColorBrush x:Key="TreeRowSelectedBrush" Color="#DCEBFA" />
    <SolidColorBrush x:Key="TreeRowInactiveSelectedBrush" Color="#E7EEF6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#DCEBFA" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E7EEF6" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1F1F1F" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1F1F1F" />
</ResourceDictionary>
